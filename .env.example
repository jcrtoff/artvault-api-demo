# Copy to .env.local and fill in.
#
# These are read server-side only (no NEXT_PUBLIC_ prefix). The API key must
# never reach the browser — all ArtVault calls go through Next.js server
# components / route handlers acting as a thin proxy. A real customer would do
# the same: a public Bearer key in client JS is a leak.

# Base URL of the Client API, including the /api/v1/client suffix.
#   Local:  http://localhost:35100/api/v1/client
#   Prod:   https://api.artvault.international/api/v1/client
ARTVAULT_API_BASE=http://localhost:35100/api/v1/client

# A real av_live_ key, minted from Account -> API Keys (needs the client_api role).
ARTVAULT_API_KEY=av_live_replace_me
